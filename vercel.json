{
  "rewrites": [
    {
      "source": "/sitemap-index.xml",
      "destination": "/sitemap-index.xml"
    },
    {
      "source": "/sitemap-cities.xml",
      "destination": "/sitemap-cities.xml"
    },
    {
      "source": "/sitemap-zips-1.xml",
      "destination": "/sitemap-zips-1.xml"
    },
    {
      "source": "/sitemap-zips-2.xml",
      "destination": "/sitemap-zips-2.xml"
    },
    {
      "source": "/$1.xml",
      "destination": "/$1.xml"
    },
    {
      "source": "/api/generate-sitemap",
      "destination": "/api/generate-sitemap"
    },
    {
      "source": "/marketplace/:path*",
      "destination": "/api/marketplace/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap-index.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ]
}
